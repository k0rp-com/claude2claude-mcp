# Two paired projects. Names are arbitrary identifiers.
PROJECT_A_NAME=project-a
PROJECT_A_TOKEN=replace-with-long-random-secret-A

PROJECT_B_NAME=project-b
PROJECT_B_TOKEN=replace-with-long-random-secret-B

# Where to store the SQLite DB (must be writable).
DB_PATH=/workspace/data.db

# Server port (must be 3000 in this container to match the public preview URL).
PORT=3000
HOST=0.0.0.0

# Long-poll cap (seconds). Client may request shorter via ?wait=
MAX_LONG_POLL_SECONDS=30

# Log level: debug | info | warn | error
LOG_LEVEL=info
